# ─── Environment Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in the values.

# Custom path to Chrome/Chromium binary (required for tempmail.la provider)
# CHROME_PATH=/usr/bin/google-chrome

# Server port (default: 3001)
# PORT=3001

# Cloudflare Worker URL (for hanzzcreator.xyz custom domain provider)
# After deploying the worker, replace with your worker URL
# WORKER_URL=https://hanzzcreator-mail.your-subdomain.workers.dev
