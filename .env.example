# ─── Environment Configuration ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Server port (default: 3001)
# PORT=3001

# Frontend API URL (Vite picks this up automatically)
# Defaults to http://localhost:3001/api if not set
# VITE_API_URL=http://localhost:3001/api

# Cloudflare Worker URL (for custom domain provider)
# Deploy the worker first, then paste your worker URL here
# WORKER_URL=https://your-worker-name.your-subdomain.workers.dev
